  "customProviders": [
    {
      "id": "custom-openai-compatible",
      "name": "自定义 OpenAI 兼容 API",
      "providerType": "custom",
      "description": "适用于第三方 OpenAI 兼容 API",
      "fields": [
        {"name": "baseUrl", "label": "API 地址", "type": "text", "placeholder": "https://your-api.com/v1", "required": true},
        {"name": "model", "label": "模型名称", "type": "text", "placeholder": "gpt-4o", "required": true},
        {"name": "apiKey", "label": "API Key", "type": "password", "required": true}
      ]
    },
    {
      "id": "custom-azure",
      "name": "Azure OpenAI",
      "providerType": "azure",
      "description": "微软 Azure OpenAI 服务",
      "fields": [
        {"name": "baseUrl", "label": "端点地址", "type": "text", "placeholder": "https://xxx.openai.azure.com", "required": true},
        {"name": "model", "label": "部署名称", "type": "text", "placeholder": "gpt-4o", "required": true},
        {"name": "apiKey", "label": "API Key", "type": "password", "required": true}
      ]
    },
    {
      "id": "custom-ollama",
      "name": "本地 Ollama",
      "providerType": "ollama",
      "description": "本地部署的 Ollama 服务",
      "fields": [
        {"name": "baseUrl", "label": "服务地址", "type": "text", "default": "http://localhost:11434", "required": true},
        {"name": "model", "label": "模型名称", "type": "text", "placeholder": "llama3.3", "required": true}
      ]
    }
